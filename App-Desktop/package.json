{
  "name": "app-desktop",
  "version": "1.0.0",
  "description": "App electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-packager . app-desktop --out dist/ --arch x64 --platform win32 --extra-resource node_modules/sqlite3/lib/binding/napi-v6-win32-unknown-x64",
    "build-linux": "electron-packager . app-desktop --out dist/ --arch x64 --platform linux",
    "prepack-linux": "cd dist/app-desktop-linux-x64/resources/app && npm i sqlite3",
    "prepack-win": "cd dist/app-desktop-win32-x64/resources/app && npm i sqlite3 && mv ../napi-v6-win32-unknown-x64 node_modules/sqlite3/lib/binding/",
    "make-deb": "electron-installer-debian --src ./dist/app-desktop-linux-x64/ --dest ./dist/ --arch amd64",
    "make-exe": "electron-installer-windows --src ./dist/app-desktop-win32-x64/ --dest ./dist/"
  },
  "keywords": [
    "electron",
    "sqlite3"
  ],
  "author": "Maicon J. Hoppe",
  "license": "MIT",
  "devDependencies": {
    "electron": "^27.0.4",
    "electron-installer-debian": "^3.2.0",
    "electron-installer-windows": "^3.0.0",
    "electron-packager": "^17.1.2",
    "sqlite3": "^5.1.6"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.0"
  }
}
